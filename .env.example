# OpenRouter API key — get yours at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-key-here

# Victim model (primary)
VICTIM_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct

# Victim model (cross-model comparison)
VICTIM_MODEL_2=openrouter/qwen/qwen-2.5-7b-instruct

# Firewall model
FIREWALL_MODEL=openrouter/anthropic/claude-opus-4-5

# Phoenix trace collection
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
